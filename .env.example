# Copy to .env and adjust. Local dev works with all defaults (SQLite).
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*

# Database — default SQLite. For MySQL 8.0 (AWS RDS), set DB_ENGINE=mysql:
# DB_ENGINE=mysql
# DB_NAME=fluxtrack
# DB_USER=fluxtrack
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Microsoft Entra ID (Phase 2)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
