# Copy to .env and set the DB_* values for your local SQL Server Express instance.
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*

# Database — SQL Server only (mssql-django + ODBC Driver 18). NOT sa.
DB_NAME=fluxtrack
DB_USER=fluxtrack_app
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=1433
# Local Express uses a self-signed cert; prod (RDS) uses a real cert chain:
DB_ODBC_EXTRA=Encrypt=yes;TrustServerCertificate=yes
# DB_TEST_NAME=test_fluxtrack   # override per parallel test run (Wave 2 isolation)
# DB_TRUSTED_CONNECTION=yes      # local LocalDB / Windows-auth only; leave unset for SQL auth (prod/RDS)

# Microsoft Entra ID SSO (social-auth AzureADTenantOAuth2PKCE)
# _KEY = Entra app (client) ID; _SECRET = client secret value; _TENANT_ID = directory (tenant) ID (D-04)
# SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_KEY=
# SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_SECRET=
# SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_TENANT_ID=

# --- Web push (VAPID, NOTIF-02) ---
# Real values are generated locally by py-vapid (see Plan 05-02 Task 3); the
# private key PEM is gitignored and must NEVER be committed (threat T-05-03).
# VAPID_PUBLIC_KEY   -- base64url application server key from `vapid --applicationServerKey`
# VAPID_PRIVATE_KEY_PATH -- path to the gitignored PEM, e.g. keys/private_key.pem
# VAPID_SUB          -- contact URI, e.g. mailto:ifo@mmcm.edu.ph
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PATH=keys/private_key.pem
VAPID_SUB=mailto:ifo@mmcm.edu.ph
