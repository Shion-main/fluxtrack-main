# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Django
db.sqlite3
db.sqlite3-journal
/media/
/staticfiles/
.env

# Web push VAPID keys — the private key PEM is a secret (threat T-05-03),
# never committed; the whole keys/ dir is generated locally per-environment.
*.pem
keys/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# POC scratch screenshots/artifacts (keep app.py as reference)
poc/*.png
poc/*.pdf

# Raw source datasets (may contain PII / be large) — never committed
/data/raw/
.gstack/

# graphify — transient build output + large regenerable diff baseline
# (the graph deliverables graph.json / graph.html / GRAPH_REPORT.md are committed under .planning/graphs/)
graphify-out/
.planning/graphs/.last-build-snapshot.json
