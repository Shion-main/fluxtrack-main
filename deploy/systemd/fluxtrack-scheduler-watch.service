[Unit]
Description=Check the FluxTrack scheduler heartbeat
After=network-online.target fluxtrack-scheduler.service

[Service]
Type=oneshot
User=fluxtrack
Group=www-data
WorkingDirectory=/srv/fluxtrack/current
EnvironmentFile=/etc/fluxtrack/fluxtrack.env
ExecStart=/srv/fluxtrack/venv/bin/python manage.py checkscheduler
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
